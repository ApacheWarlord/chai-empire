{
  "expo": {
    "name": "Chai Empire",
    "slug": "chai-empire",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/branding/icon.png",
    "scheme": "chaiempire",
    "userInterfaceStyle": "dark",
    "description": "India-native idle business game prototype where players grow a roadside chai stall into a full chai empire.",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/branding/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1208"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chaiempire.game"
    },
    "android": {
      "package": "com.chaiempire.game",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/adaptive-icon-foreground.png",
        "backgroundColor": "#1C1208"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/branding/favicon.png"
    },
    "extra": {
      "build": {
        "appId": "com.chaiempire.game",
        "environment": "production-ready-prototype"
      }
    }
  }
}
